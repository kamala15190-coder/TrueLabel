# ============================================================
# TrueLabel — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und fülle die Werte.
# Die App läuft auch KOMPLETT OHNE diese Werte (Dev-Modus):
#   - Ohne DATABASE_URL  -> eingebettete Postgres-DB (PGlite) in ./.data
#   - Ohne MISTRAL_API_KEY -> Community-Features laufen im manuellen Modus
#   - Ohne GOOGLE_*      -> Google-Login-Button wird ausgeblendet
#   - Ohne STRIPE_*      -> Premium-Kauf zeigt "noch nicht eingerichtet"
# ============================================================

# Postgres-Verbindungs-URL (Produktion: Supabase). Lokal leer lassen
# -> eingebettete PGlite-DB in ./.data. SSL wird automatisch aktiviert.
# Supabase: Dashboard -> Project Settings -> Database -> "Connection string"
# -> "Transaction pooler" (Port 6543) wählen, Passwort einsetzen, z. B.:
# postgresql://postgres.<ref>:<passwort>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Port, auf dem die App lauscht (Server: 3100, da 3000 belegt ist)
PORT=3000

# Session-Secret. Erzeugen mit:  openssl rand -base64 32
AUTH_SECRET=

# Öffentliche Basis-URL (für OAuth-Redirects & Stripe-Checkout)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Diese E-Mail wird bei der Registrierung automatisch zum Admin
ADMIN_EMAIL=

# Mistral AI (https://console.mistral.ai) — Foto-Extraktion & Korrektur-Triage
MISTRAL_API_KEY=

# Harte KI-Budgetbremse in Cent pro Monat (3800 = 38 €, Marge unter 40 €)
AI_BUDGET_CENTS=3800

# Google OAuth (optional). Redirect-URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (Premium-Abo, 2,49 €/Monat bzw. 19,99 €/Jahr)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Kontakt-E-Mail für den OpenFoodFacts User-Agent (API-Richtlinie)
OFF_CONTACT=
